{
  "name": "hhi-proposal-app2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/tsx/dist/cli.mjs scripts/dev-context-task-runner.ts dev-server -- node node_modules/tsx/dist/cli.mjs scripts/dev-with-dev-context.ts",
    "build": "node node_modules/tsx/dist/cli.mjs scripts/dev-context-task-runner.ts build -- node node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "node node_modules/tsx/dist/cli.mjs scripts/dev-context-task-runner.ts lint -- node node_modules/eslint/bin/eslint.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "qstash:test": "dotenv -e .env.local -- node node_modules/tsx/dist/cli.mjs scripts/qstash-test.ts",
    "dev-context:serve": "node node_modules/tsx/dist/cli.mjs hhi-dev-context/scripts/run-server.ts",
    "dev-context:collect-git": "node node_modules/tsx/dist/cli.mjs hhi-dev-context/scripts/collect-git.ts",
    "dev-context:verify": "node node_modules/tsx/dist/cli.mjs scripts/dev-context-verify.ts",
    "dev-context:mcp": "node node_modules/tsx/dist/cli.mjs hhi-dev-context-mcp/scripts/run-server.ts",
    "seed:hero-backgrounds": "npx tsx scripts/seed-hero-backgrounds.ts"
  },
  "prisma": {
    "seed": "node node_modules/tsx/dist/cli.mjs prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@aws-sdk/client-s3": "^3.700.0",
