# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

.vercel

# clerk configuration (can include secrets)
/.clerk/

# hhi-dev-context local SQLite DB
.hhi-dev-context/

# Claude Code local settings (not committed)
.claude/settings.local.json

# Claude Code runtime
.claude/scheduled_tasks.lock

# Add gitignore entries for investigation reports
# Open .gitignore in your editor and add these lines:
*_INVESTIGATION.md
WEB_READINESS_*.md
AI_TIGHTENING_*.md

# Generated migration backfill artifact (one-shot SQL output, never committed)
scripts/migration-backfill.sql

# Generated extension .zip artifacts (re-run scripts/package-zillow-extension.ts)
dist/
