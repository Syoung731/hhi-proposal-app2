generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoomPricingTier {
  PROFILE
  AI_ESTIMATE
  MANUAL
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StylePreset {
  id        String    @id @default(cuid())
  name      String    @unique
  prompt    String
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  media     Media[]
  projects  Project[]
  rooms     Room[]

  @@index([isActive, sortOrder])
}

model Project {
  id                       String                    @id @default(cuid())
  slug                     String                    @unique
  status                   ProjectStatus             @default(DRAFT)
  title                    String
  subtitle                 String?
  coverHeroImageId         String?
  objective                String?
  supportingText           String?
  bullets                  String[]                  @default([])
  scopeOverview            String?
  publishedVersion         Int                       @default(0)
  // Cursor for the version the public link should resolve to. Null = follow latest snapshot.
  // Set by the Send-to-Client flow (Cleanup H) so re-publishing doesn't move the URL out from under the client.
  clientFacingVersion      Int?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  addressLine1             String?
  addressLine2             String?
  city                     String?
  state                    String?
  zip                      String?
  client1First             String?
  client1Last              String?
  client2First             String?
  client2Last              String?
  transcriptText           String?
  stylePresetId            String?
  stylePreset              StylePreset?              @relation(fields: [stylePresetId], references: [id], onDelete: SetNull)
  investmentLineItems      InvestmentLineItem[]
  media                    Media[]
  publishedSnapshots       PublishedSnapshot[]
  rooms                    Room[]
  timelinePhases           TimelinePhase[]
  proposal                 Proposal?
  extensionPairCodes       ExtensionPairCode[]
  zillowBrowserConnections ZillowBrowserConnection[]
  estimateJobs             EstimateJob[]
  defaultCeilingHeightFt   Float?                    @default(9)
  projectQA                Json?
  proposalDeck             ProposalDeck?
  // Rendr LiDAR integration (optional)
  rendrSpaceId             Int?
  rendrProjectId           Int?
  rendrLinkedAt            DateTime?
  rendrImportedAt          DateTime?

  // Design/Feasibility Retainer (shown on investment + retainer slides)
  retainerEnabled  Boolean @default(true)
  retainerPercent  Float   @default(0.08)
  retainerRoundTo  Int     @default(1000)
  retainerOverride Int?

  // Scope flag: when true, the default deck includes an Addition Overview slide.
  hasAddition Boolean @default(false)

  // Structured objective pillars for the new Objective slide layout.
  // Shape: Array<{ title: string; body: string }> (exactly 3 items when set).
  // Null when the project has never run the new Generate Overview flow — the
  // deck falls back to the legacy objective/supportingText/bullets prose.
  objectivePillars Json?

  // Phase 8A.1 — Investment tab display-group order.
  // Array of slug strings representing the user-preferred render order for
  // display groups (primary-suite, kitchen-dining, bedroom-<id>, ...).
  // Empty array = use the default priority constant. "cope" is always forced
  // last server-side regardless of what's stored here.
  displayGroupOrder Json @default("[]")

  // Project Overhead (COPE) generation state (Phase 8C).
  // Doubles as an idempotency lock — writers acquire GENERATING via a
  // conditional updateMany() so simultaneous triggers can't race.
  copeStatus      CopeStatus @default(IDLE)
  copeGeneratedAt DateTime?
  copeError       String?

  @@index([status])
  @@index([createdAt])
  @@index([stylePresetId])
}

/**
 * Project-level Project Overhead (COPE) generation state.
 * One COPE AIEstimate per project at a time; this enum tracks whether a
 * regeneration is in-flight, succeeded, or failed since the last reset.
 */
enum CopeStatus {
  IDLE
  GENERATING
  READY
  FAILED
}

model ExtensionPairCode {
  id              String    @id @default(cuid())
  code            String    @unique
  projectId       String
  createdByUserId String?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  usedAt          DateTime?
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([expiresAt])
}

enum ZillowConnectionStatus {
  PENDING
  CONNECTED
  FAILED
  EXPIRED
}

enum ZillowHandshakeMethod {
  DIRECT
  MANUAL
}

model ZillowBrowserConnection {
  id                String                 @id @default(cuid())
  userId            String // Clerk user id (authenticated user who started the session)
  projectId         String?
  status            ZillowConnectionStatus @default(PENDING)
  nonce             String                 @unique
  createdAt         DateTime               @default(now())
  expiresAt         DateTime
  verifiedAt        DateTime?
  browserMetadata   Json? // { userAgent?, browserFamily?, version?, platform? }
  extensionMetadata Json? // { extensionId?, extensionVersion? }
  handshakeMethod   ZillowHandshakeMethod  @default(DIRECT)
  project           Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([nonce])
  @@index([userId])
  @@index([projectId])
  @@index([expiresAt])
  @@index([status])
}

model Proposal {
  id                 String  @id @default(cuid())
  projectId          String  @unique
  isPublic           Boolean @default(false)
  publicLayoutConfig Json?
  project            Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isPublic])
}

model Room {
  id                         String           @id @default(cuid())
  projectId                  String
  roomTypeId                 String?
  stylePresetId              String?
  sectionTypeId              String?
  estPricePerSqFt            Float?
  lengthFt                   Float?
  widthFt                    Float?
  ceilingHeightFt            Float?
  lengthIn                   Int?
  widthIn                    Int?
  ceilingHeightIn            Int?
  scopeNarrative             String           @default("")
  sortOrder                  Int              @default(0)
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  name                       String
  scopeSource                String           @default("AI")
  scopeUpdatedAt             DateTime         @default(now())
  selectedRenderMediaId      String?
  // Section / measurement fields
  measurementMode            MeasurementMode?
  areaSqFt                   Float?
  quantity                   Int?
  origin                     SectionOrigin    @default(MANUAL)
  // Estimating fields
  estimateUnit               EstimateUnit?
  customUnitLabel            String?
  unitRate                   Float?
  unitQuantity               Float?
  unitQuantityManualOverride Boolean          @default(false)
  roomTemplateId             String?
  pricingTier                RoomPricingTier  @default(PROFILE)
  isProjectOverhead          Boolean          @default(false)
  // Section pricing (Low/Target/High)
  unitRateLow                Float?
  unitRateTarget             Float?
  unitRateHigh               Float?
  totalLow                   Float?
  totalTarget                Float?
  totalHigh                  Float?
  pricingNotes               String?
  scopeQA                    Json?
  estimateStaleReason        String?
  bucket                     SectionBucket    @default(BASE)

  // Phase 8A.1 — Investment tab display-group assignment.
  // Slug naming:
  //   - Fixed groups: "primary-suite" | "kitchen-dining" | "living-spaces"
  //                   | "utility" | "outdoor" | "storage" | "ungrouped" | "cope"
  //   - Per-room groups: "bedroom-<roomId>" | "bathroom-<roomId>" | "carolina-room-<roomId>"
  // Set automatically at Room creation via the classifier. Nullable only for
  // legacy rows before the backfill migration runs.
  displayGroupId    String?
  // Sort order within displayGroupId (and at root level when the slug is
  // "ungrouped"). Written by user drag operations.
  displayGroupOrder Int              @default(0)

  // Structured measurement fields (from Rendr LiDAR or manual entry)
  wallsSF                    Float?
  ceilingSF                  Float?
  perimeterLF                Float?
  paintableSF                Float?
  windowCount                Int?
  windowsSF                  Float?
  doorCount                  Int?
  doorsSF                    Float?
  measurementSource          String? // 'rendr' | 'transcript' | 'manual'
  rendrCeilingHeightFt       Float? // Ceiling height from Rendr geometry (preserved)
  // Rendr room mapping (persists the import pairing)
  rendrRoomMappings          Json? // [{ index: number, label: string }]
  // Kitchen/Bath structured detail (Phase 7B will populate)
  roomDetail                 Json?
  media                      Media[]
  subAreas                   RoomSubArea[]
  jobItems                   JobItem[]
  project                    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roomType                   RoomType?        @relation(fields: [roomTypeId], references: [id], onDelete: SetNull)
  stylePreset                StylePreset?     @relation(fields: [stylePresetId], references: [id], onDelete: SetNull)
  sectionType                SectionType?     @relation(fields: [sectionTypeId], references: [id], onDelete: SetNull)
  roomTemplate               RoomTemplate?    @relation(fields: [roomTemplateId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, bucket])
  @@index([projectId, sortOrder])
  @@index([projectId, isProjectOverhead])
  @@index([projectId, displayGroupId, displayGroupOrder])
  @@index([roomTypeId])
  @@index([stylePresetId])
  @@index([sectionTypeId])
  @@index([origin])
  @@index([estimateUnit])
  @@index([roomTemplateId])
}

/// Optional finer-grained measurement segments for a Room/Section
model RoomSubArea {
  id              String   @id @default(cuid())
  roomId          String
  name            String
  lengthIn        Int?
  widthIn         Int?
  ceilingHeightIn Int?
  areaSqFt        Float?
  sortOrder       Int      @default(0)
  includeInArea   Boolean  @default(true) // <‑‑ add this line
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, sortOrder])
}

enum MediaPlacement {
  SECTION
  FRONT_PAGE
  UNASSIGNED
}

model Media {
  id              String         @id @default(cuid())
  projectId       String
  roomId          String?
  kind            MediaKind
  url             String
  fileKey         String
  /**
   * Original source URL (e.g. Zillow image URL) for duplicate detection.
   */
  sourceUrl       String?
  width           Int?
  height          Int?
  caption         String?
  tags            String[]
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  sourceMediaId   String?
  parentMediaId   String?
  editInstruction String?
  stylePresetId   String?
  renderProvider  String?
  renderModel     String?
  renderStatus    RenderStatus?
  renderError     String?
  promptVersion   Int            @default(1)
  placement       MediaPlacement @default(UNASSIGNED)
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room            Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  sourceMedia     Media?         @relation("MediaSource", fields: [sourceMediaId], references: [id], onDelete: SetNull)
  renderingsFrom  Media[]        @relation("MediaSource")
  parent          Media?         @relation("MediaParent", fields: [parentMediaId], references: [id], onDelete: SetNull)
  children        Media[]        @relation("MediaParent")
  stylePreset     StylePreset?   @relation(fields: [stylePresetId], references: [id], onDelete: SetNull)
  type            MediaType      @default(EXISTING)

  @@index([projectId])
  @@index([roomId])
  @@index([projectId, kind])
  @@index([projectId, type])
  @@index([projectId, sortOrder])
  @@index([projectId, placement])
  @@index([sourceMediaId])
  @@index([parentMediaId])
  @@index([stylePresetId])
}

model TimelinePhase {
  id                  String            @id @default(cuid())
  projectId           String
  phase               TimelinePhaseType
  /// Per-project override for the canonical phase name. Null = use default copy.
  nameOverride        String?
  /// Per-project override for the canonical phase description. Null = use default copy.
  descriptionOverride String?
  /// Editable duration text (e.g. "4 to 8 weeks"). Empty for milestone rows.
  durationText        String            @default("")
  sortOrder           Int               @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  project             Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, sortOrder])
}

model InvestmentLineItem {
  id              String        @id @default(cuid())
  projectId       String
  bucket          SectionBucket
  label           String
  rangeLow        Int?
  rangeTarget     Int?
  rangeHigh       Int?
  notes           String?
  overrideLow     Int?
  overrideTarget  Int?
  overrideHigh    Int?
  overrideNotes   String?
  isOverride      Boolean       @default(false)
  includeInTotals Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, bucket])
  @@index([projectId])
  @@index([projectId, sortOrder])
}

model PublishedSnapshot {
  id               String         @id @default(cuid())
  projectId        String
  version          Int
  snapshotJson     Json
  createdAt        DateTime       @default(now())
  // Send-to-Client tracking — populated by Cleanup H, null until first send.
  sentAt           DateTime?
  sentByEmployeeId String?
  sentToEmail      String?
  label            String?
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sentByEmployee   Employee?      @relation(fields: [sentByEmployeeId], references: [id], onDelete: SetNull)
  emailSendLogs    EmailSendLog[]
  pdfDownloadLogs   PdfDownloadLog[]
  shareLinkCopyLogs ShareLinkCopyLog[]

  @@unique([projectId, version])
  @@index([projectId])
  @@index([sentByEmployeeId])
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaKind {
  COVER
  BEFORE
  AFTER
  INSPIRATION
  PLAN
  TEAM
  OTHER
}

enum MediaType {
  HERO
  EXISTING
  RENDERING
}

enum RenderStatus {
  QUEUED
  RENDERING
  DONE
  FAILED
}

enum TimelinePhaseType {
  SIGN_CONTRACT
  START_DESIGN
  DESIGN_FEASIBILITY
  PRECONSTRUCTION
  CONSTRUCTION
}

enum SectionCategory {
  INTERIOR
  EXTERIOR
  SYSTEMS
  WHOLE_HOME
  ADDITION
  FAST
}

enum MeasurementMode {
  NONE
  DIMENSIONS
  AREA
  COUNT
}

enum EstimateUnit {
  SF
  LF
  EA
  SQ
  HR
  DAY
  ROOM
  UNIT
  GAL
  CUSTOM
}

enum SectionOrigin {
  MANUAL
  AI_TRANSCRIPT
  TEMPLATE
  IMPORTED
}

enum SectionBucket {
  BASE
  ALTERNATE
  ALLOWANCE
}

enum PricingBasis {
  NONE
  PER_SF
  PER_EACH
  PER_JOB
}

model Employee {
  id               String              @id @default(cuid())
  firstName        String
  lastName         String
  roleTitle        String? // e.g., Project Director, PM, Designer
  email            String?             @unique
  phone            String?
  isActive         Boolean             @default(true)
  isAdmin          Boolean             @default(false)
  sortOrder        Int                 @default(0)
  // Email-send tracking (Cleanup F). dailySentCount is rolled over when
  // dailySentResetAt < now by sendProposalEmail.
  lastSentAt       DateTime?
  dailySentCount   Int                 @default(0)
  dailySentResetAt DateTime?
  // Email signature (Cleanup G). Consumed by buildEmployeeSignature() to
  // compose the HTML + text signature blocks used in outbound proposal email.
  // signatureEnabled=false → builder returns empty strings.
  headshotUrl      String?
  jobTitle         String? // client-facing title (distinct from operational roleTitle)
  signatureQuote   String?
  directPhone      String?
  mobilePhone      String?
  linkedInUrl      String?
  signatureEnabled Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sentSnapshots    PublishedSnapshot[]
  emailSendLogs    EmailSendLog[]
  pdfDownloadLogs   PdfDownloadLog[]
  shareLinkCopyLogs ShareLinkCopyLog[]

  @@index([sortOrder])
}

// Singleton: one row for company-wide settings. Use findFirst and create if none.
model CompanySettings {
  id                        String   @id @default(cuid())
  companyName               String   @default("")
  addressLine1              String?
  addressLine2              String?
  city                      String?
  state                     String?
  zip                       String?
  phone                     String?
  email                     String?
  websiteUrl                String?
  logoUrl                   String?
  logoLightUrl              String?
  logoDarkUrl               String?
  primaryColor              String?
  primaryColorHex           String? // accent color
  textColorHex              String? // text/headline color
  defaultProposalDisclaimer String?  @default("")
  defaultTimelineNote       String?
  integrationsJson          Json?
  roomTypeLowPct            Float? // default -10 in UI; low = target * (1 + lowPct/100)
  roomTypeHighPct           Float? // default +10 in UI; high = target * (1 + highPct/100)
  anthropicModel            String? // selected Claude model ID (e.g. "claude-sonnet-4-6")
  aiEstimateConcurrency     Int? // how many rooms estimate in parallel via background jobs; null -> default 8
  autoGenerateCope          Boolean  @default(true) // auto-fire project-overhead (COPE) regen when an EstimateJob lands COMPLETED
  geminiImageModel          String? // Gemini image/vision model (e.g. "gemini-2.5-flash-image")
  geminiImageGenModel       String? // Gemini text-to-image Imagen model (e.g. "imagen-4.0-fast-generate-001")
  coreValuesDefaultsJson    Json? // GlobalCoreValuesSettings: default values, layout, headline for new core-values slides
  copeDefaultsJson          Json? // GlobalCopeSettings: default COPE items, layout, headline for new cope-page slides
  nextStepsDefaultsJson     Json? // GlobalNextStepsSettings: default steps, layout, headline for new next-steps slides
  designBuildDefaultsJson   Json? // GlobalDesignBuildSettings: default pillars, guarantees, diagram for new design-build-advantage slides
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// Singleton company for value pillars / why-us defaults (single-tenant).
model Company {
  id            String         @id @default(cuid())
  name          String         @default("Default Company")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  valuePillars  ValuePillar[]
  whyUsDefaults WhyUsDefaults?
}

model ValuePillar {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title       String // pillar title (e.g. "No Change Order Guarantee")
  body        String     @default("") // pillar body copy
  brandIconId String?
  brandIcon   BrandIcon? @relation(fields: [brandIconId], references: [id], onDelete: SetNull)

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, sortOrder])
}

model WhyUsDefaults {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title String @default("Why Us")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandIcon {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  // PNG icon stored in R2
  imageUrl     String // public URL to the PNG in R2
  imageKey     String // object key in R2 for deletes / moves
  width        Int? // optional metadata
  height       Int? // optional metadata
  // Deprecated: legacy inline SVG markup, kept nullable for safe migrations
  svg          String?
  tags         String[]
  category     String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  backgrounds  BrandBackground[]
  valuePillars ValuePillar[]

  @@index([name])
}

model BrandBackground {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  baseColorHex    String? // e.g. #FFFFFF
  // Overlay choice: either an uploaded/generated image OR a pattern icon reference
  overlayImageUrl String?
  overlayImageKey String?
  overlayIconId   String? // references BrandIcon.id (optional)
  overlayOpacity  Int      @default(6) // percent 0-100 (we’ll keep it percent)
  overlayScale    Int      @default(100) // percent
  overlaySpacing  Int      @default(120) // px
  overlayRotation Int      @default(0) // degrees
  // Cached PNG preview for fast grids/pickers
  previewImageUrl String?
  previewImageKey String?
  // Availability toggle: controls whether this background can be selected in the app UI.
  // Active toggle: internal flag for turning a background on/off globally (e.g. experiments, rollouts).
  isAvailable     Boolean  @default(true)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  tags            String[] // optional for search/filter
  // Generation provenance — null for manually-configured or pre-refactor records
  generationMode  String? // "subtle-texture" | "blueprint-overlay" | "slide-visual"
  stylePreset     String? // "architectural" | "editorial" | "technical" | "warm-luxury"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  compositionSeed    String?
  textZoneSuggestion Json?

  overlayIcon BrandIcon?  @relation(fields: [overlayIconId], references: [id], onDelete: SetNull)
  deckSlides  DeckSlide[]

  @@index([isActive, sortOrder])
}

// Library of room types (e.g. Kitchen, Primary Bath). Reusable across projects.
model RoomType {
  id                 String   @id @default(cuid())
  name               String
  sortOrder          Int      @default(0)
  active             Boolean  @default(true)
  exterior           Boolean  @default(false)
  pricePerSqFtLow    Float?
  pricePerSqFtTarget Float?
  pricePerSqFtHigh   Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  rooms              Room[]

  @@index([sortOrder])
}

// ---------------------------------------------------------------------------
// Global Photo Library (past work, reusable across projects)
// ---------------------------------------------------------------------------

enum LibraryUseType {
  BEFORE
  AFTER
  IN_PROGRESS
  RENDER
  DETAIL
  LIFESTYLE
}

enum LibraryQuality {
  HERO_READY
  STANDARD
}

enum LibraryOrientation {
  LANDSCAPE
  PORTRAIT
  SQUARE
  PANORAMA
  UNKNOWN
}

model LibraryMedia {
  id                String             @id @default(cuid())
  fileKey           String
  url               String
  thumbnailKey      String?
  thumbnailUrl      String?
  title             String?
  description       String?
  roomTypeIds       String[]
  tags              String[]
  useType           LibraryUseType     @default(AFTER)
  quality           LibraryQuality     @default(STANDARD)
  orientation       LibraryOrientation @default(UNKNOWN)
  marketingApproved Boolean            @default(false)
  sourceProjectName String?
  sourceProjectId   String?
  photographer      String?
  createdByUserId   String?
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([useType])
  @@index([quality])
  @@index([orientation])
  @@index([marketingApproved])
  @@index([createdAt])
  @@index([sortOrder])
}

model LibraryTag {
  id         String   @id @default(cuid())
  tag        String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  usageCount Int      @default(0)
}

// Section types (UI: Sections). Defines category, default measurement mode, estimate unit, and pricing.
model SectionType {
  id                     String              @id @default(cuid())
  name                   String              @unique
  category               SectionCategory
  defaultMeasurementMode MeasurementMode
  defaultEstimateUnit    EstimateUnit
  customUnitLabel        String?
  pricingBasis           PricingBasis        @default(NONE)
  priceLow               Float?
  priceTarget            Float?
  priceHigh              Float?
  pricePerSqFtLow        Float? // deprecated: use priceLow when pricingBasis = PER_SF
  pricePerSqFtTarget     Float?
  pricePerSqFtHigh       Float?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  rooms                  Room[]
  pricingSourceRooms     PricingSourceRoom[]

  @@index([category])
}

// ---------------------------------------------------------------------------
// Third-party API integrations (e.g. JobTread). Credentials stored encrypted.
// ---------------------------------------------------------------------------
model Integration {
  id              String    @id @default(cuid())
  provider        String // e.g. "jobtread"
  name            String // e.g. "JobTread Production"
  isActive        Boolean   @default(true)
  baseUrl         String?
  encryptedSecret String?
  metaJson        Json?
  lastTestedAt    DateTime?
  lastStatus      String? // success | error | never_tested
  lastMessage     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([provider, name])
  @@index([provider])
  @@index([isActive])
}

// ---------------------------------------------------------------------------
// Testimonial Library (curated testimonials for proposal slides)
// ---------------------------------------------------------------------------

model Testimonial {
  id          String   @id @default(cuid())
  quote       String
  clientName  String
  projectName String?
  rating      Int      @default(5) // 1–5
  source      String   @default("manual") // "google" | "manual"
  approved    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Canonical JobTread budget (single source of truth for official pricing).
// ---------------------------------------------------------------------------
model SyncedBudgetJob {
  id                String            @id @default(cuid())
  jobId             String            @unique
  jobName           String
  jobNumber         String?
  stage             String?
  location          String?
  lastSyncedAt      DateTime?
  lastSyncStatus    String? // success | warning | error | never_synced
  lastSyncMessage   String?
  lastRowCount      Int               @default(0)
  officialSellTotal Decimal           @default(0) @db.Decimal(19, 4)
  officialCostTotal Decimal           @default(0) @db.Decimal(19, 4)
  sourceSummarySell Decimal?          @db.Decimal(19, 4)
  sourceSummaryCost Decimal?          @db.Decimal(19, 4)
  rawBudgetJson     Json?
  sourceRowCount    Int? // row count from last sync (for fingerprint comparison)
  sourceSellTotal   Decimal?          @db.Decimal(19, 4)
  sourceCostTotal   Decimal?          @db.Decimal(19, 4)
  sourceFingerprint String? // hash of normalized payload; unchanged => skip sync
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  rows              SyncedBudgetRow[]

  @@index([lastSyncStatus])
  @@index([lastSyncedAt])
}

model SyncedBudgetRow {
  id                   String          @id @default(cuid())
  jobId                String
  jobName              String
  externalBudgetItemId String
  groupName            String? // cost group name (item's direct group)
  costGroupId          String? // item's cost group id
  parentCostGroupId    String? // parent cost group id (null = top-level = room)
  parentCostGroupName  String? // parent cost group name (room name when item is under a trade)
  itemName             String
  costCode             String?
  costCodeName         String?
  costType             String?
  unit                 String?
  quantity             Decimal?        @db.Decimal(19, 6)
  unitCost             Decimal?        @db.Decimal(19, 4)
  unitPrice            Decimal?        @db.Decimal(19, 4)
  extCost              Decimal         @db.Decimal(19, 4)
  extSell              Decimal         @db.Decimal(19, 4)
  rawPayloadJson       Json
  syncedAt             DateTime        @default(now())
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  job                  SyncedBudgetJob @relation(fields: [jobId], references: [jobId], onDelete: Cascade)

  @@unique([jobId, externalBudgetItemId])
  @@index([jobId])
  @@index([groupName])
  @@index([costCode])
}

// ---------------------------------------------------------------------------
// JobTread pricing staging layer (derived from SyncedBudgetJob / SyncedBudgetRow).
// ---------------------------------------------------------------------------

model PricingSourceJob {
  id                 String    @id @default(cuid())
  jobId              String    @unique
  jobName            String
  jobNumber          String?
  includeInPricing   Boolean   @default(false)
  sourceLastSyncedAt DateTime?
  totalCost          Decimal   @default(0) @db.Decimal(19, 4)
  totalSell          Decimal   @default(0) @db.Decimal(19, 4)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  rooms  PricingSourceRoom[]
  trades PricingSourceTrade[]
}

model PricingSourceRoom {
  id                 String   @id @default(cuid())
  jobId              String
  pricingJobId       String
  roomKey            String
  roomName           String
  normalizedRoomName String?
  sectionTypeId      String?
  sectionTypeSource  String?
  includeInPricing   Boolean  @default(false)
  autoDetectedSqFt   Decimal? @db.Decimal(19, 2)
  manualSqFtOverride Decimal? @db.Decimal(19, 2)
  totalCost          Decimal  @default(0) @db.Decimal(19, 4)
  totalSell          Decimal  @default(0) @db.Decimal(19, 4)
  costPerSqFt        Decimal? @db.Decimal(19, 4)
  sellPerSqFt        Decimal? @db.Decimal(19, 4)
  sqFtSource         String?
  hasValidSqFt       Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  job         PricingSourceJob     @relation(fields: [pricingJobId], references: [id], onDelete: Cascade)
  sectionType SectionType?         @relation(fields: [sectionTypeId], references: [id], onDelete: SetNull)
  trades      PricingSourceTrade[]

  @@unique([jobId, roomName])
  @@index([sectionTypeId])
  @@index([includeInPricing])
  @@index([jobId])
}

model PricingSourceTrade {
  id        String   @id @default(cuid())
  jobId     String
  roomId    String
  tradeName String
  totalCost Decimal  @default(0) @db.Decimal(19, 4)
  totalSell Decimal  @default(0) @db.Decimal(19, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job  PricingSourceJob  @relation(fields: [jobId], references: [jobId], onDelete: Cascade)
  room PricingSourceRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, tradeName])
  @@index([jobId])
}

// ---------------------------------------------------------------------------
// Proposal Deck — persisted slide deck per project.
// ---------------------------------------------------------------------------

model ProposalDeck {
  id        String      @id @default(cuid())
  projectId String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  slides    DeckSlide[]
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DeckSlide {
  id             String           @id @default(cuid())
  deckId         String
  type           String
  layoutKey      String
  order          Int              @default(0)
  isEnabled      Boolean          @default(true)
  isUserHidden   Boolean          @default(false)
  isUserModified Boolean          @default(false)
  source         String           @default("manual")
  sectionId      String?
  headline       String?
  subheadline    String?
  body           String?
  content        Json?
  isLocked       Boolean          @default(false)
  lockPosition   String?
  backgroundId   String?
  textZone       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deck           ProposalDeck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  background     BrandBackground? @relation(fields: [backgroundId], references: [id], onDelete: SetNull)

  @@index([deckId, order])
  @@index([deckId, type])
  @@index([sectionId])
  @@index([backgroundId])
}

// ---------------------------------------------------------------------------
// AI Pricing / Catalog
// ---------------------------------------------------------------------------

model PricingCatalogItem {
  id                String             @id @default(cuid())
  jobtreadId        String             @unique
  name              String
  description       String?
  costCode          String?
  costType          String?
  unitCost          Float?
  unitPrice         Float?
  unit              String             @default("EA")
  trade             String?
  active            Boolean            @default(true)
  lastSyncedAt      DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  roomTemplateItems RoomTemplateItem[]
  estimateLineItems EstimateLineItem[]

  @@index([trade])
  @@index([active])
  @@index([name])
}

model RoomTemplate {
  id                String                   @id @default(cuid())
  jobtreadId        String?                  @unique
  name              String
  displayName       String?
  active            Boolean                  @default(true)
  isProjectOverhead Boolean                  @default(false)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  tradeGroups       RoomTemplateTradeGroup[]
  aiEstimates       AIEstimate[]
  rooms             Room[]

  @@index([active])
}

model RoomTemplateTradeGroup {
  id              String             @id @default(cuid())
  roomTemplateId  String
  name            String
  jobtreadGroupId String?
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  roomTemplate    RoomTemplate       @relation(fields: [roomTemplateId], references: [id], onDelete: Cascade)
  items           RoomTemplateItem[]

  @@index([roomTemplateId])
}

model RoomTemplateItem {
  id             String                 @id @default(cuid())
  tradeGroupId   String
  catalogItemId  String?
  jobtreadItemId String?
  name           String
  costCode       String?
  costType       String?
  sortOrder      Int                    @default(0)
  isActive       Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  tradeGroup     RoomTemplateTradeGroup @relation(fields: [tradeGroupId], references: [id], onDelete: Cascade)
  catalogItem    PricingCatalogItem?    @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@index([tradeGroupId])
  @@index([catalogItemId])
}

// ---------------------------------------------------------------------------
// AI Estimates
// ---------------------------------------------------------------------------

model AIEstimate {
  id               String             @id @default(cuid())
  projectId        String
  sectionId        String
  roomTemplateId   String?
  status           String             @default("draft")
  totalCost        Float?
  totalPrice       Float?
  promptTokens     Int?
  completionTokens Int?
  rawResponse      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  roomTemplate     RoomTemplate?      @relation(fields: [roomTemplateId], references: [id], onDelete: SetNull)
  lineItems        EstimateLineItem[]
  priceCorrections PriceCorrection[]

  @@index([projectId])
  @@index([sectionId])
  @@index([roomTemplateId])
  @@index([status])
}

model EstimateLineItem {
  id               String              @id @default(cuid())
  estimateId       String
  catalogItemId    String?
  tradeGroup       String
  name             String
  description      String?
  quantity         Float               @default(1)
  unit             String              @default("EA")
  unitCost         Float               @default(0)
  unitPrice        Float               @default(0)
  totalCost        Float               @default(0)
  totalPrice       Float               @default(0)
  totalPriceLow    Float               @default(0)
  totalPriceHigh   Float               @default(0)
  source           String              @default("AI_PRICED")
  confidence       Float?
  notes            String?
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  estimate         AIEstimate          @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  catalogItem      PricingCatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  priceCorrections PriceCorrection[]

  @@index([estimateId])
  @@index([catalogItemId])
}

model PriceCorrection {
  id              String           @id @default(cuid())
  estimateId      String
  lineItemId      String
  field           String
  originalValue   Float
  correctedValue  Float
  catalogItemName String?
  tradeGroup      String?
  roomTemplateId  String?
  notes           String?
  createdAt       DateTime         @default(now())
  estimate        AIEstimate       @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  lineItem        EstimateLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)

  @@index([estimateId])
  @@index([lineItemId])
  @@index([catalogItemName])
  @@index([tradeGroup])
  @@index([roomTemplateId])
}

// ---------------------------------------------------------------------------
// Estimate Jobs (background / parallel bulk estimate generation)
// Phase 8B: a job represents a single bulk run; items are per-room work units
// processed by QStash workers. Source of truth for progress + retries.
// ---------------------------------------------------------------------------

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

enum JobItemStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model EstimateJob {
  id             String    @id @default(cuid())
  projectId      String
  status         JobStatus @default(QUEUED)
  totalItems     Int
  completedItems Int       @default(0)
  failedItems    Int       @default(0)
  createdById    String? // optional Clerk userId; nullable while auth is disabled in dev
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  metadata       Json? // audit payload (question-answer snapshot, kicker, etc.)
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items          JobItem[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model JobItem {
  id            String        @id @default(cuid())
  estimateJobId String
  roomId        String
  status        JobItemStatus @default(QUEUED)
  attempts      Int           @default(0)
  startedAt     DateTime?
  finishedAt    DateTime?
  error         String?
  estimateId    String? // FK-ish pointer to resulting AIEstimate row (not a relation — AIEstimate lifecycle is independent)
  payload       Json // snapshot of inputs the worker needs: { roomTemplateId, scopeNarrative, projectContext?, squareFootage? }
  estimateJob   EstimateJob   @relation(fields: [estimateJobId], references: [id], onDelete: Cascade)
  room          Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([estimateJobId])
  @@index([roomId])
  @@index([status])
}

