generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StylePreset {
  id        String   @id @default(cuid())
  name      String   @unique
  prompt    String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  media     Media[]
  projects  Project[]
  rooms     Room[]

  @@index([isActive, sortOrder])
}

model Project {
  id                  String               @id @default(cuid())
  slug                String               @unique
  status              ProjectStatus        @default(DRAFT)
  title               String
  subtitle            String?
  coverHeroImageId    String?
  objective           String?
  publishedVersion    Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  zip                 String?
  client1First        String?
  client1Last         String?
  client2First        String?
  client2Last         String?
  transcriptText      String?
  stylePresetId       String?
  stylePreset         StylePreset?         @relation(fields: [stylePresetId], references: [id], onDelete: SetNull)
  investmentLineItems InvestmentLineItem[]
  media               Media[]
  publishedSnapshots  PublishedSnapshot[]
  rooms               Room[]
  timelinePhases      TimelinePhase[]
  proposal            Proposal?
  extensionPairCodes       ExtensionPairCode[]
  zillowBrowserConnections ZillowBrowserConnection[]

  @@index([status])
  @@index([createdAt])
  @@index([stylePresetId])
}

model ExtensionPairCode {
  id              String    @id @default(cuid())
  code            String    @unique
  projectId       String
  createdByUserId String?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  usedAt          DateTime?
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([expiresAt])
}

enum ZillowConnectionStatus {
  PENDING
  CONNECTED
  FAILED
  EXPIRED
}

enum ZillowHandshakeMethod {
  DIRECT
  MANUAL
}

model ZillowBrowserConnection {
  id                String                   @id @default(cuid())
  userId            String                   // Clerk user id (authenticated user who started the session)
  projectId         String?
  status            ZillowConnectionStatus   @default(PENDING)
  nonce             String                   @unique
  createdAt         DateTime                 @default(now())
  expiresAt         DateTime
  verifiedAt        DateTime?
  browserMetadata   Json?                    // { userAgent?, browserFamily?, version?, platform? }
  extensionMetadata Json?                  // { extensionId?, extensionVersion? }
  handshakeMethod   ZillowHandshakeMethod   @default(DIRECT)
  project           Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([nonce])
  @@index([userId])
  @@index([projectId])
  @@index([expiresAt])
  @@index([status])
}

model Proposal {
  id                  String   @id @default(cuid())
  projectId            String   @unique
  isPublic             Boolean  @default(false)
  publicLayoutConfig   Json?
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isPublic])
}

model Room {
  id                   String            @id @default(cuid())
  projectId            String
  roomTypeId           String?
  stylePresetId        String?
  sectionTypeId        String?
  estPricePerSqFt      Float?
  lengthFt             Float?
  widthFt              Float?
  ceilingHeightFt      Float?
  lengthIn             Int?
  widthIn              Int?
  ceilingHeightIn      Int?
  scopeNarrative       String            @default("")
  sortOrder            Int               @default(0)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  name                 String
  scopeSource          String            @default("AI")
  scopeUpdatedAt       DateTime          @default(now())
  selectedRenderMediaId String?
  // Section / measurement fields
  measurementMode      MeasurementMode?
  areaSqFt             Float?
  quantity             Int?
  origin               SectionOrigin     @default(MANUAL)
  // Estimating fields
  estimateUnit         EstimateUnit?
  customUnitLabel      String?
  unitRate             Float?
  unitQuantity         Float?
  unitQuantityManualOverride Boolean @default(false)
  // Section pricing (Low/Target/High)
  unitRateLow          Float?
  unitRateTarget       Float?
  unitRateHigh         Float?
  totalLow             Float?
  totalTarget          Float?
  totalHigh            Float?
  pricingNotes         String?
  bucket               SectionBucket           @default(BASE)
  media                     Media[]
  project                   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roomType                  RoomType?           @relation(fields: [roomTypeId], references: [id], onDelete: SetNull)
  stylePreset               StylePreset?        @relation(fields: [stylePresetId], references: [id], onDelete: SetNull)
  sectionType               SectionType?        @relation(fields: [sectionTypeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, bucket])
  @@index([projectId, sortOrder])
  @@index([roomTypeId])
  @@index([stylePresetId])
  @@index([sectionTypeId])
  @@index([origin])
  @@index([estimateUnit])
}

enum MediaPlacement {
  SECTION
  FRONT_PAGE
  UNASSIGNED
}

model Media {
  id              String          @id @default(cuid())
  projectId       String
  roomId          String?
  kind            MediaKind
  url             String
  fileKey         String
  /** Original source URL (e.g. Zillow image URL) for duplicate detection. */
  sourceUrl       String?
  width           Int?
  height          Int?
  caption         String?
  tags            String[]
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  sourceMediaId   String?
  parentMediaId   String?
  editInstruction String?
  stylePresetId   String?
  renderProvider  String?
  renderModel     String?
  renderStatus    RenderStatus?
  renderError     String?
  promptVersion   Int             @default(1)
  placement       MediaPlacement  @default(UNASSIGNED)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  room            Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull)
  sourceMedia     Media?          @relation("MediaSource", fields: [sourceMediaId], references: [id], onDelete: SetNull)
  renderingsFrom  Media[]         @relation("MediaSource")
  parent          Media?          @relation("MediaParent", fields: [parentMediaId], references: [id], onDelete: SetNull)
  children        Media[]        @relation("MediaParent")
  stylePreset     StylePreset?    @relation(fields: [stylePresetId], references: [id], onDelete: SetNull)
  type            MediaType      @default(EXISTING)

  @@index([projectId])
  @@index([roomId])
  @@index([projectId, kind])
  @@index([projectId, type])
  @@index([projectId, sortOrder])
  @@index([projectId, placement])
  @@index([sourceMediaId])
  @@index([parentMediaId])
  @@index([stylePresetId])
}

model TimelinePhase {
  id           String            @id @default(cuid())
  projectId    String
  phase        TimelinePhaseType
  durationText String            @default("")
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, sortOrder])
}

model InvestmentLineItem {
  id              String        @id @default(cuid())
  projectId       String
  bucket          SectionBucket
  label           String
  rangeLow        Int?
  rangeTarget     Int?
  rangeHigh       Int?
  notes           String?
  overrideLow     Int?
  overrideTarget  Int?
  overrideHigh    Int?
  overrideNotes   String?
  isOverride      Boolean       @default(false)
  includeInTotals Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, bucket])
  @@index([projectId])
  @@index([projectId, sortOrder])
}

model PublishedSnapshot {
  id           String   @id @default(cuid())
  projectId    String
  version      Int
  snapshotJson Json
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId])
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaKind {
  COVER
  BEFORE
  AFTER
  INSPIRATION
  PLAN
  TEAM
  OTHER
}

enum MediaType {
  HERO
  EXISTING
  RENDERING
}

enum RenderStatus {
  QUEUED
  RENDERING
  DONE
  FAILED
}

enum TimelinePhaseType {
  DESIGN_FEASIBILITY
  PRECONSTRUCTION
  CONSTRUCTION
}

enum SectionCategory {
  INTERIOR
  EXTERIOR
  SYSTEMS
  WHOLE_HOME
  ADDITION
  FAST
}

enum MeasurementMode {
  NONE
  DIMENSIONS
  AREA
  COUNT
}

enum EstimateUnit {
  SF
  LF
  EA
  SQ
  HR
  DAY
  ROOM
  UNIT
  GAL
  CUSTOM
}

enum SectionOrigin {
  MANUAL
  AI_TRANSCRIPT
  TEMPLATE
  IMPORTED
}

enum SectionBucket {
  BASE
  ALTERNATE
  ALLOWANCE
}

enum PricingBasis {
  NONE
  PER_SF
  PER_EACH
  PER_JOB
}

model Employee {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  roleTitle String?  // e.g., Project Director, PM, Designer
  email     String?  @unique
  phone     String?
  isActive  Boolean  @default(true)
  isAdmin   Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

// Singleton: one row for company-wide settings. Use findFirst and create if none.
model CompanySettings {
  id                      String   @id @default(cuid())
  companyName             String   @default("")
  addressLine1            String?
  addressLine2            String?
  city                    String?
  state                   String?
  zip                     String?
  phone                   String?
  email                   String?
  websiteUrl              String?
  logoUrl                 String?
  logoLightUrl            String?
  logoDarkUrl             String?
  primaryColor            String?
  primaryColorHex         String?  // accent color
  textColorHex            String?  // text/headline color
  defaultProposalDisclaimer String? @default("")
  defaultTimelineNote     String?
  integrationsJson       Json?
  roomTypeLowPct         Float?   // default -10 in UI; low = target * (1 + lowPct/100)
  roomTypeHighPct        Float?   // default +10 in UI; high = target * (1 + highPct/100)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// Singleton company for value pillars / why-us defaults (single-tenant).
model Company {
  id              String          @id @default(cuid())
  name            String          @default("Default Company")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  valuePillars    ValuePillar[]
  whyUsDefaults   WhyUsDefaults?
}

model ValuePillar {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title       String    // pillar title (e.g. "No Change Order Guarantee")
  body        String    @default("") // pillar body copy
  brandIconId String?
  brandIcon   BrandIcon? @relation(fields: [brandIconId], references: [id], onDelete: SetNull)

  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId, sortOrder])
}

model WhyUsDefaults {
  id         String   @id @default(cuid())
  companyId  String   @unique
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title      String   @default("Why Us")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BrandIcon {
  id        String           @id @default(cuid())
  slug      String           @unique
  name      String
  // PNG icon stored in R2
  imageUrl  String           // public URL to the PNG in R2
  imageKey  String           // object key in R2 for deletes / moves
  width     Int?             // optional metadata
  height    Int?             // optional metadata
  // Deprecated: legacy inline SVG markup, kept nullable for safe migrations
  svg       String?
  tags      String[]
  category  String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  backgrounds BrandBackground[]
  valuePillars ValuePillar[]

  @@index([name])
}

model BrandBackground {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  baseColorHex   String?  // e.g. #FFFFFF
  // Overlay choice: either an uploaded/generated image OR a pattern icon reference
  overlayImageUrl String?
  overlayImageKey String?
  overlayIconId   String?  // references BrandIcon.id (optional)
  overlayOpacity  Int      @default(6)   // percent 0-100 (we’ll keep it percent)
  overlayScale    Int      @default(100) // percent
  overlaySpacing  Int      @default(120) // px
  overlayRotation Int      @default(0)   // degrees
  // Cached PNG preview for fast grids/pickers
  previewImageUrl String?
  previewImageKey String?
  // Availability toggle: controls whether this background can be selected in the app UI.
  // Active toggle: internal flag for turning a background on/off globally (e.g. experiments, rollouts).
  isAvailable     Boolean  @default(true)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  tags            String[] // optional for search/filter
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  overlayIcon BrandIcon? @relation(fields: [overlayIconId], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder])
}

// Library of room types (e.g. Kitchen, Primary Bath). Reusable across projects.
model RoomType {
  id                 String   @id @default(cuid())
  name               String
  sortOrder          Int      @default(0)
  active             Boolean  @default(true)
  exterior           Boolean  @default(false)
  pricePerSqFtLow    Float?
  pricePerSqFtTarget Float?
  pricePerSqFtHigh   Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  rooms              Room[]

  @@index([sortOrder])
}

// ---------------------------------------------------------------------------
// Global Photo Library (past work, reusable across projects)
// ---------------------------------------------------------------------------

enum LibraryUseType {
  BEFORE
  AFTER
  IN_PROGRESS
  RENDER
  DETAIL
  LIFESTYLE
}

enum LibraryQuality {
  HERO_READY
  STANDARD
}

enum LibraryOrientation {
  LANDSCAPE
  PORTRAIT
  SQUARE
  PANORAMA
  UNKNOWN
}

model LibraryMedia {
  id                  String             @id @default(cuid())
  fileKey             String
  url                 String
  thumbnailKey        String?
  thumbnailUrl        String?
  title               String?
  description         String?
  roomTypeIds         String[]
  tags                String[]
  useType             LibraryUseType     @default(AFTER)
  quality             LibraryQuality     @default(STANDARD)
  orientation         LibraryOrientation @default(UNKNOWN)
  marketingApproved   Boolean            @default(false)
  sourceProjectName   String?
  sourceProjectId     String?
  photographer        String?
  createdByUserId     String?
  sortOrder           Int                @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([useType])
  @@index([quality])
  @@index([orientation])
  @@index([marketingApproved])
  @@index([createdAt])
  @@index([sortOrder])
}

model LibraryTag {
  id         String   @id @default(cuid())
  tag        String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  usageCount Int      @default(0)
}

// Section types (UI: Sections). Defines category, default measurement mode, estimate unit, and pricing.
model SectionType {
  id                    String           @id @default(cuid())
  name                  String           @unique
  category              SectionCategory
  defaultMeasurementMode MeasurementMode
  defaultEstimateUnit   EstimateUnit
  customUnitLabel       String?
  pricingBasis          PricingBasis      @default(NONE)
  priceLow              Float?
  priceTarget           Float?
  priceHigh             Float?
  pricePerSqFtLow       Float?           // deprecated: use priceLow when pricingBasis = PER_SF
  pricePerSqFtTarget    Float?
  pricePerSqFtHigh      Float?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  rooms                 Room[]

  @@index([category])
}
