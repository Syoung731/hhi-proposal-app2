// ---------------------------------------------------------------------------
// Email Send Audit Log (Cleanup F)
// ---------------------------------------------------------------------------
// Per-send audit trail for every outbound proposal email. Written by
// sendProposalEmail() — both successes and failures. Cleanup H reads the
// `error` column for retry logic. Relations set to SetNull so retention of
// audit history doesn't block deletion of snapshots or employees.
// ---------------------------------------------------------------------------

model EmailSendLog {
  id                String             @id @default(cuid())
  snapshotId        String?
  snapshot          PublishedSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  employeeId        String?
  employee          Employee?          @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  fromAddress       String
  toAddress         String
  subject           String
  providerName      String
  providerMessageId String?
  sentAt            DateTime           @default(now())
  error             String?
  metadataJson      Json?

  @@index([snapshotId])
  @@index([employeeId])
  @@index([sentAt])
}

// ---------------------------------------------------------------------------
// Delivery Audit Logs (Cleanup H)
// ---------------------------------------------------------------------------
// Per-action audit trails for the two non-email delivery paths: PDF download
// (in-person meetings) and share-link copy (ad-hoc delivery). Kept separate
// from EmailSendLog so per-method reporting stays simple — no delivery_type
// enum + where-clause contortions.
//
// Unlike EmailSendLog, these do NOT update PublishedSnapshot.sentAt —
// downloads and copies don't confirm the client received anything, only
// email has that signal via provider message ids.
//
// Relations use Cascade on snapshot (audit dies with the snapshot it
// references — downloads of a deleted snapshot are meaningless) and
// SetNull on employee (retention of the download event survives employee
// deletion, just with a null attribution).
// ---------------------------------------------------------------------------

model PdfDownloadLog {
  id           String            @id @default(cuid())
  snapshotId   String
  snapshot     PublishedSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  employeeId   String?
  employee     Employee?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  downloadedAt DateTime          @default(now())

  @@index([snapshotId])
  @@index([employeeId])
}

model ShareLinkCopyLog {
  id         String            @id @default(cuid())
  snapshotId String
  snapshot   PublishedSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  employeeId String?
  employee   Employee?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  copiedAt   DateTime          @default(now())

  @@index([snapshotId])
  @@index([employeeId])
}
