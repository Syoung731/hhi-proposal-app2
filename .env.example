# ============================================================================
# .env.example — environment variable manifest for hhi-proposal-app2
#
# Copy to .env.local and fill in real values for local development. Production
# values are configured in Vercel project settings (see VERCEL_DEPLOY_CHECKLIST.md).
#
# Sections: REQUIRED, OPTIONAL, DEV-ONLY.
# ============================================================================


# ============================================================================
# REQUIRED — app fails or core flow breaks without these
# ============================================================================

# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Pooled connection string used by the app at runtime.
# Different in dev/prod (separate Neon branches).
DATABASE_URL="postgresql://user:password@host:5432/hhi_proposals?schema=public"

# Direct (non-pooled) connection string used by `prisma migrate` and the seed.
# Different in dev/prod (separate Neon branches).
DIRECT_URL="postgresql://user:password@host:5432/hhi_proposals?schema=public"


# ─── Authentication (Clerk) ─────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys.
# Use pk_test_/sk_test_ in dev, pk_live_/sk_live_ in production.
# Both keys MUST come from the same Clerk app and same environment — mismatched
# keys cause an "infinite redirect loop" error.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Tells Clerk SDK where the app's sign-in / sign-up pages live, so links
# inside <SignIn />, <UserButton />, redirects from clerkMiddleware, etc.
# all point to the right place. The values below match the catch-all routes
# at app/sign-in/[[...sign-in]]/page.tsx and app/sign-up/[[...sign-up]]/page.tsx.
# Sign-up is invitation-only (Steve provisions users via the Clerk dashboard);
# the /sign-up page renders an "invitation only" notice rather than a real form.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"


# ─── Object Storage (Cloudflare R2) ─────────────────────────────────────────
# Different in dev/prod (separate buckets). Production should use a custom
# domain on R2_PUBLIC_BASE_URL once the bucket is wired to one.
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET="hhi-proposals-dev"
R2_PUBLIC_BASE_URL="https://pub-<hash>.r2.dev"

# Legacy compatibility — set R2_* unless migrating from S3. The app reads
# both prefixes and prefers R2_*. AWS aliases:
#   AWS_S3_ENDPOINT, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
#   S3_BUCKET, S3_PUBLIC_BASE_URL, PUBLIC_MEDIA_BASE_URL, AWS_REGION
# Don't fill both — the prefix-mixing behavior is intentional but confusing.


# ─── App URL ────────────────────────────────────────────────────────────────
# Base URL the app uses to construct self-referential URLs (PDF render,
# QStash webhook callbacks, Rendr import callbacks, email links).
# Different in dev/prod. Code falls back to "http://localhost:3000" when
# unset, which silently breaks PDF + email + Rendr in production. Required.
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ─── Encryption Secrets ─────────────────────────────────────────────────────
# 32+ bytes each. MUST be different values in dev vs prod (cross-environment
# decryption is a leak risk). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Encrypts JobTread / Rendr / Anthropic / Gemini API keys stored in the
# Integration table.
INTEGRATION_ENCRYPTION_KEY="..."

# HMAC signs the short-lived bypass token used by the headless-Chromium PDF
# render path. See app/lib/pdf-render-token.ts.
PDF_RENDER_SECRET="..."


# ─── Background Jobs (Upstash QStash) ───────────────────────────────────────
# In dev: run `npx @upstash/qstash-cli dev` and copy the printed values here.
# In prod: configure in the Upstash console and copy live values to Vercel.

# Token used by the app to publish jobs.
QSTASH_TOKEN="..."

# Endpoint URL the app POSTs to.
#   dev:  http://127.0.0.1:8080
#   prod: https://qstash.upstash.io
QSTASH_URL="http://127.0.0.1:8080"

# Signing keys verified inside QStash webhook routes
# (/api/jobs/cope-generate, /api/jobs/estimate-room, /api/qstash/test).
QSTASH_CURRENT_SIGNING_KEY="..."
QSTASH_NEXT_SIGNING_KEY="..."


# ============================================================================
# OPTIONAL — feature degrades or specific path fails if missing; app boots fine
# ============================================================================

# Comma-separated emails counted as bootstrap admins by the demotion-guard
# in app/admin/settings/actions.ts:1412. The guard prevents the last admin
# from being demoted; ADMIN_EMAILS contributes to that count alongside the
# Employee table and the hardcoded super admin. Set if you want to allow
# the only-employee-admin to demote themselves without first onboarding
# another employee admin.
# ADMIN_EMAILS="dalton@hhi-builders.com,danielle@hhi-builders.com"


# ─── AI Providers ───────────────────────────────────────────────────────────
# Both providers are normally configured via Settings → Integrations
# (admin UI), which encrypts the keys with INTEGRATION_ENCRYPTION_KEY and
# stores them in the DB. The env vars below are read by a small number of
# code paths that don't go through the integration helper:

# Read by /api/rendr/match-rooms only. Set this if you use the Rendr
# space-to-room matching feature; otherwise the integration-secret path is
# enough for every other AI call.
# ANTHROPIC_API_KEY="sk-ant-..."

# Read by scripts/seed-hero-backgrounds.ts only (for one-time seeding of
# background images). The runtime app uses the integration-secret path.
# GEMINI_API_KEY="..."

# Image-rendering provider for slide background generation. Defaults to
# "gemini" when unset. Don't change unless implementing a new provider.
# RENDER_PROVIDER="gemini"


# ─── Google Places (address autocomplete on Overview tab) ───────────────────
# Get a key at https://console.cloud.google.com/apis/credentials with
# Places API (New) enabled. Without it, the address field still works
# but autocomplete is disabled.
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=""


# ─── Zillow Importer extension wiring ───────────────────────────────────────
# Chrome Web Store URL shown in the "Connect Zillow extension" modal. Set
# once the extension is published; otherwise the modal hides the link.
# NEXT_PUBLIC_ZILLOW_EXTENSION_STORE_URL=""

# Feature flag — enables nonce-based direct browser handshake for the
# extension. When unset or "false", only the manual pair-code path is offered.
# ENABLE_DIRECT_ZILLOW_HANDSHAKE="true"

# Comma-separated Chrome extension IDs allowed to complete the direct
# handshake. When set, extensionId becomes required on /api/extension/connection/verify.
# ZILLOW_EXTENSION_ALLOWLIST=""


# ─── JobTread integration ───────────────────────────────────────────────────
# Cap on jobs the budget sync pulls per run. Default: '5'.
# JOBTREAD_SYNC_MAX_JOBS="5"


# ─── Email send rate limit ──────────────────────────────────────────────────
# Per-employee per-day cap on outgoing proposal emails. Has a code default;
# set this only if you need to override.
# EMPLOYEE_DAILY_EMAIL_LIMIT="50"


# ============================================================================
# ⚠️  DEV-ONLY — DO NOT SET IN PRODUCTION  ⚠️
# ============================================================================
#
# These variables exist solely for local development workflows. Setting them
# on Vercel will either silently corrupt audit attribution (DEV_EMPLOYEE_ID),
# attempt to phone home to a non-existent local service (HHI_DEV_CONTEXT_*),
# or enable verbose logging that leaks sensitive data into production logs.
#
# Every entry below stays commented out by default. Uncomment in .env.local
# only when actively using the corresponding dev tool.
# ============================================================================

# Override for getCurrentEmployeeId() — pin a specific Employee.id as the
# attributed actor for send/PDF/email actions. Useful when several devs share
# a DB and want to test attribution behavior. NEVER set in production.
# DEV_EMPLOYEE_ID=""

# Local hhi-dev-context observability service. The app posts debug events
# over HTTP when enabled. The companion service runs separately on port 3999.
# HHI_DEV_CONTEXT_ENABLED="true"
# HHI_DEV_CONTEXT_BASE_URL="http://127.0.0.1:3999"
# HHI_DEV_CONTEXT_PORT="3999"
# HHI_DEV_CONTEXT_DB="./hhi-dev-context.db"

# Optional task-status string forwarded to dev-context's git collector.
# HHI_TASK_STATUS=""

# Verbose logging for the JobTread budget sync pipeline. Pollutes logs.
# DEBUG_JOBTREAD_SYNC="true"

# Single-row test mode for the JobTread sync (skips the full sync; useful
# when iterating on row-shape parsing).
# SYNC_ONE_ROW_TEST="true"

# ─── Google Drive import (Media tab) ────────────────────────────────────────
# Browser Picker + drive.file scope; server downloads the picked files. All
# three are public (exposed to the browser) and restricted by domain/API in
# the Google Cloud Console. No client secret is used by this flow.
#   CLIENT_ID  — OAuth 2.0 Web client ID (…apps.googleusercontent.com)
#   API_KEY    — API key restricted to the Google Picker API
#   APP_ID     — the Google Cloud project NUMBER (for the Picker)
NEXT_PUBLIC_GOOGLE_CLIENT_ID="..."
NEXT_PUBLIC_GOOGLE_API_KEY="..."
NEXT_PUBLIC_GOOGLE_APP_ID="..."

# ─── Presentation Studio (new AI deck builder) ──────────────────────────────
# Gates the in-development /admin/projects/[id]/studio section + its nav tab.
# Set to "true" on the presentation-studio preview deployment; leave unset/false
# in production until the builder is ready to launch. Baked in at build time.
NEXT_PUBLIC_STUDIO_ENABLED="false"
