# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hhi_proposals?schema=public"

# Clerk (admin auth)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Admin allowlist (comma-separated emails or Clerk user IDs)
ADMIN_EMAILS=
# or: ADMIN_USER_IDS=

# R2 / S3-compatible object storage (presigned uploads)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
# Or S3 equivalents: AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, S3_BUCKET, S3_PUBLIC_BASE_URL

# Base URL for PDF export (server-side Playwright loads this URL)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Playwright (PDF export) - optional; defaults work for most setups
# PLAYWRIGHT_BROWSERS_PATH=0
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Gemini image model for PNG icon generation (image-capable)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
