{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx tsc*)",
      "Bash(npx prisma*)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "MultiEdit(*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(rm -rf /*)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && git add -A && git diff-index --quiet HEAD 2>/dev/null || git commit -m \"checkpoint: auto-commit after Claude Code task\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
